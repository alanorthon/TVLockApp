<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@android:color/black">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Установка PIN-кода"
        android:textSize="28sp"
        android:textColor="@color/tv_text_primary"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/instruction_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Введите 4-значный PIN-код"
        android:textSize="18sp"
        android:textColor="@color/tv_text_secondary"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/pin_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="____"
        android:textSize="36sp"
        android:textColor="@color/tv_text_primary"
        android:fontFamily="monospace"
        android:letterSpacing="0.5"
        android:layout_marginBottom="48dp" />

    <!-- Number pad -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Row 1: 1, 2, 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_1"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="1"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_2"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="2"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_3"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="3"
                android:textSize="24sp"
                android:layout_margin="8dp" />

        </LinearLayout>

        <!-- Row 2: 4, 5, 6 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_4"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="4"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_5"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="5"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_6"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="6"
                android:textSize="24sp"
                android:layout_margin="8dp" />

        </LinearLayout>

        <!-- Row 3: 7, 8, 9 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_7"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="7"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_8"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="8"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_9"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="9"
                android:textSize="24sp"
                android:layout_margin="8dp" />

        </LinearLayout>

        <!-- Row 4: Clear, 0, Delete -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_clear"
                style="@style/PinButtonSecondary"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="C"
                android:textSize="20sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_0"
                style="@style/PinButton"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="0"
                android:textSize="24sp"
                android:layout_margin="8dp" />

            <Button
                android:id="@+id/btn_delete"
                style="@style/PinButtonSecondary"
                android:background="@drawable/focusable_item_background"
                android:focusable="true"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="⌫"
                android:textSize="20sp"
                android:layout_margin="8dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>